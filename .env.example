TELEGRAM_BOT_TOKEN=123456:replace_me
TARGET_CHAT_ID=-1003643946438
CRON_SECRET=replace_with_long_random_string

# Optional: comma-separated ids allowed to run edit/post commands.
# If empty, the bot allows commands from TARGET_CHAT_ID and from private chats.
ADMIN_CHAT_IDS=

# Daily autopost loop.
AUTO_POST=true
AUTO_CHECK_SECONDS=300
AUTO_LOOKBACK_DAYS=2

# Bot/runtime settings.
STATE_DB=state/mlb_daily_results.db
# Required on Vercel. Use Vercel KV/Upstash Redis and copy KV_URL or REDIS_URL.
KV_URL=
REDIS_URL=
LOCAL_TZ=Europe/Moscow
MLB_TZ=America/New_York
TEAM_EMOJI=😀
DRY_RUN=false
DELETE_WEBHOOK_ON_START=true
FAST_PITCHER_RECORDS=true
